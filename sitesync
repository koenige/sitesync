#!/bin/zsh

# Sync local site folders to remote servers with rsync (SSH).
# Copyright © 2025-2026 Gustaf Mossakowski
# SPDX-License-Identifier: MIT

#r = recurse into directories
#L = transform symlink into referent file/dir
#p = preserve permissions
#t = preserve times
#D = preserve device files (super-user only), special files
#u = skip files that are newer on the receiver
#v =  increase verbosity

folder="$HOME/Sites"

sitesync_usage() {
	cat <<EOF
Usage: sitesync SITE COMMAND
       sitesync help

Commands:
  help         Show this help
  test         Dry-run sync local -> remote
  go           Sync local -> remote
  init         Pull remote -> local
  inittest     Dry-run pull remote -> local
  command      Print rsync command (push)
  commandinit  Print rsync command (pull)

Site config in \$HOME/Sites/SITE/: .rsync-remote, .rsync-filter, optional .rsync-port
EOF
}

sitesync_rsync() {
	rsync "$@" | grep -E '^deleting|[^/]$|^$'
	return $pipestatus[1]
}

if [[ -z "$1" ]]; then
	sitesync_usage
	exit 1
fi

if [[ "$1" == "help" || "$1" == "--help" || "$1" == "-h" ]]; then
	sitesync_usage
	exit 0
fi

if [[ -z "$2" ]]; then
	sitesync_usage
	exit 1
fi

if [[ "$2" == "help" || "$2" == "--help" || "$2" == "-h" ]]; then
	sitesync_usage
	exit 0
fi

if [[ ! -d "$folder/$1" ]]; then
	echo "No site $1 available" >&2
	exit 1
fi
if [[ ! -f "$folder/$1/.rsync-filter" ]]; then
	echo "Missing .rsync-filter for $1" >&2
	exit 1
fi
if [[ ! -f "$folder/$1/.rsync-remote" ]]; then
	echo "Missing .rsync-remote for $1" >&2
	exit 1
fi
if [[ ! -f "$folder/$1/.rsync-port" ]]; then
	port=22
else
	while read line; do 
		port=$line
	done < "$folder/$1/.rsync-port"
fi

while read line; do    
    remote=$line
done < "$folder/$1/.rsync-remote"

if [[ $2 == "test" ]] then
	echo "-- Test run --"
	sitesync_rsync -rLtDuvcin -e "ssh -p $port" --no-perms --no-owner --no-group --no-times --filter="merge $folder/$1/.rsync-filter" $folder/$1/ $remote --delete
elif [[ $2 == "inittest" ]] then
	echo "-- Test initial run (get data from remote) --"
	sitesync_rsync -rLtDuvcin -e "ssh -p $port" --no-perms --no-owner --no-group --no-times --filter="merge $folder/$1/.rsync-filter" $remote $folder/$1/ --delete
elif [[ $2 == "init" ]] then
	echo "-- Inital run (get data from remote) --"
	sitesync_rsync -rLtDuvc -e "ssh -p $port" --filter="merge $folder/$1/.rsync-filter" $remote $folder/$1/ --delete
elif [[ $2 == "command" ]] then
	echo "rsync -e 'ssh -p $port' -rLtDuvcn --no-perms --no-owner --no-group --no-times --filter=\"merge $folder/$1/.rsync-filter\" $folder/$1/ $remote --delete | grep -E '^deleting|[^/]$|^$'"
elif [[ $2 == "commandinit" ]] then
	echo "rsync -rLtDuvcin -e 'ssh -p $port' --filter=\"merge $folder/$1/.rsync-filter\" $remote $folder/$1/ --delete | grep -E '^deleting|[^/]$|^$'"
elif [[ $2 == "go" ]] then
	echo "-- Site sync --"
	sitesync_rsync -rLtDuvc -e "ssh -p $port" --no-perms --no-owner --no-group --no-times --filter="merge $folder/$1/.rsync-filter" $folder/$1/ $remote --delete
else
	echo "Unknown command: $2" >&2
	sitesync_usage
	exit 1
fi
